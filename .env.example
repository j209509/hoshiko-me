# ============================================================
# hoshiko.me — 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
# cp .env.example .env.local
# ============================================================

# --------------------------------------------------------
# App
# --------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=hoshiko.me

# --------------------------------------------------------
# NextAuth.js v5
# openssl rand -base64 32 で生成
# --------------------------------------------------------
AUTH_SECRET=your-secret-here
AUTH_URL=http://localhost:3000

# Google OAuth（Google でログイン機能）
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# --------------------------------------------------------
# Database — Supabase (PostgreSQL)
# --------------------------------------------------------
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# --------------------------------------------------------
# Supabase
# --------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --------------------------------------------------------
# Stripe（決済）
# --------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe 料金ID
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_STANDARD=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# --------------------------------------------------------
# Resend（メール送信）
# --------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@hoshiko.me

# --------------------------------------------------------
# Google Business API（将来 OAuth 連携用）
# --------------------------------------------------------
GOOGLE_BUSINESS_CLIENT_ID=your-client-id
GOOGLE_BUSINESS_CLIENT_SECRET=your-client-secret
